###################################
# DJANGO SETTINGS
###################################

DEBUG=False

SECRET_KEY=finai_prod_secret_key_change_this

ALLOWED_HOSTS=tadgeeg.com,www.tadgeeg.com,127.0.0.1,localhost

CSRF_TRUSTED_ORIGINS=https://tadgeeg.com,https://www.tadgeeg.com


###################################
# DATABASE (MYSQL)
###################################

DB_ENGINE=django.db.backends.mysql
DB_NAME=finai_db
DB_USER=finai_user
DB_PASSWORD=FinAI_Strong_Pass123!
DB_HOST=127.0.0.1
DB_PORT=3306


###################################
# OPENAI
###################################

OPENAI_API_KEY=sk-proj-xxxxx-REPLACE-WITH-YOUR-KEY-xxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2


###################################
# OCR ENGINE
###################################

OCR_ENGINE=tesseract
TESSERACT_PATH=/usr/bin/tesseract


###################################
# AI MODULES
###################################

ENABLE_AI=True
ENABLE_OCR=True
ENABLE_ANOMALY_DETECTION=True
ENABLE_FORECASTING=True


###################################
# EMAIL
###################################

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=admin@tadgeeg.com
EMAIL_HOST_PASSWORD=change_this_password


###################################
# STATIC / MEDIA
###################################

STATIC_ROOT=/root/FinAI-v1.2/backend/staticfiles
MEDIA_ROOT=/root/FinAI-v1.2/backend/media


###################################
# SECURITY
###################################

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True


###################################
# LOGGING
###################################

LOG_LEVEL=INFO