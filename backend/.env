# FinAI Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL (recommended for production)
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=finai_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_HOST=localhost
DATABASE_PORT=5432

# SQLite (for development/testing)
# Uncomment below to use SQLite instead
# DATABASE_ENGINE=django.db.backends.sqlite3
# DATABASE_NAME=db.sqlite3

# ============================================================================
# DJANGO CONFIGURATION
# ============================================================================

DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,finai.example.com

# Django environment
ENVIRONMENT=development
# Set to 'production' for production deployments

# ============================================================================
# OPENAI CONFIGURATION (Phase 5 - Financial Narratives)
# ============================================================================

# OpenAI API Key (for invoice extraction and financial narratives)
# Get from: https://platform.openai.com/api-keys
# IMPORTANT: Store your API key in environment variables, NOT in this file!
# In production, set via:
#   export OPENAI_API_KEY=sk-...
# Or use: docker run -e OPENAI_API_KEY=sk-... finai:latest
OPENAI_API_KEY=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
# Optional: Set specific model (default: gpt-4o-mini for vision extraction)
OPENAI_MODEL=gpt-4o-mini

# Optional: Temperature for narrative generation (0.0-1.0, default 0.7)
OPENAI_TEMPERATURE=0.7

# Optional: Timeout for OpenAI API calls (seconds)
OPENAI_TIMEOUT=30

# ============================================================================
# EXTRACTION CONFIGURATION - DUAL MODE (OpenAI + Tesseract)
# ============================================================================

# Primary extraction method (openai or tesseract)
EXTRACTION_PRIMARY_METHOD=openai

# Enable Tesseract as fallback (if available)
TESSERACT_ENABLED=True

# Tesseract command path (if different from default)
TESSERACT_CMD=tesseract

# OCR confidence threshold (0-100)
TESSERACT_CONFIDENCE_THRESHOLD=60

# Use pytesseract for invoice extraction audit
USE_PYTESSERACT_AUDIT=True

# ============================================================================
# PHASE 5 CONFIGURATION (Financial Intelligence)
# ============================================================================

# Alert Thresholds
SPEND_SPIKE_THRESHOLD=1.5              # 50% increase = 1.5x multiplier
ANOMALY_CLUSTER_THRESHOLD=5            # 5+ anomalies in 7 days
CASH_FLOW_PRESSURE_THRESHOLD=1000000   # 1M SAR
DUPLICATE_RISK_THRESHOLD=0.7           # 70+ score
BUDGET_OVERRUN_THRESHOLD=0.9           # 90% utilization

# Cash Flow Forecasting
CASH_FLOW_ANALYSIS_LOOKBACK_DAYS=90    # Analyze past 90 days for trends

# Spend Intelligence
SPEND_ANALYSIS_MONTHS=12               # Analyze past 12 months

# Vendor Risk
VENDOR_RISK_LOOKBACK_DAYS=90           # Risk analysis window

# ============================================================================
# EMAIL CONFIGURATION (Optional - for alert notifications)
# ============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=finai@example.com

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/django.log

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://finai.example.com

# CSRF Settings
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://finai.example.com

# Security headers
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Set to True in production with HTTPS
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ============================================================================
# OCR CONFIGURATION (Phase 1)
# ============================================================================

# Tesseract OCR path (for fallback if OpenAI fails)
TESSERACT_CMD=/usr/bin/tesseract
# On macOS: /usr/local/Cellar/tesseract/[version]/bin/tesseract
# On Windows: C:\Program Files\Tesseract-OCR\tesseract.exe

# ============================================================================
# COMPLIANCE & AUDIT
# ============================================================================

# Enable audit logging (Phase 3)
ENABLE_AUDIT_LOGGING=True

# Enable compliance checks (Phase 3)
ENABLE_COMPLIANCE_CHECKS=True

# Enable cross-document intelligence (Phase 4)
ENABLE_CROSS_DOCUMENT_INTELLIGENCE=True

# Enable financial intelligence (Phase 5)
ENABLE_FINANCIAL_INTELLIGENCE=True

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API Rate limiting
API_RATE_LIMIT=1000/hour

# API Timeout (seconds)
API_TIMEOUT=30

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
# Options: locmem, redis, memcache, dummy

# Redis (if using Redis cache)
# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/1

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Django shell_plus enabled
SHELL_PLUS=True

# Auto-reload on file changes
AUTORELOAD=True

# ============================================================================
# PRODUCTION RECOMMENDATIONS
# ============================================================================

# For production, change these:
# 1. Set DEBUG=False
# 2. Change SECRET_KEY to a strong random value
# 3. Update ALLOWED_HOSTS to your domain
# 4. Set SECURE_SSL_REDIRECT=True
# 5. Set SESSION_COOKIE_SECURE=True
# 6. Set CSRF_COOKIE_SECURE=True
# 7. Use a production database (PostgreSQL)
# 8. Configure email properly
# 9. Set appropriate alert thresholds for your business
# 10. Enable HTTPS

# ============================================================================
# NOTES
# ============================================================================

# - Keep this file out of version control (in .gitignore)
# - Different .env files for dev/staging/production
# - Never commit API keys or passwords
# - Rotate secrets regularly
# - Use environment-specific configuration management
