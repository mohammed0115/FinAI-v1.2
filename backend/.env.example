# FinAI Environment Configuration Template
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env file with real secrets to git

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# PostgreSQL (for production)
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=finai_db
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_password_here
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# ============================================================================
# DJANGO CONFIGURATION
# ============================================================================

DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,finai.example.com
ENVIRONMENT=development

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# ============================================================================
# EXTRACTION CONFIGURATION - DUAL MODE (OpenAI + Tesseract)
# ============================================================================

EXTRACTION_PRIMARY_METHOD=openai
TESSERACT_ENABLED=True
TESSERACT_CMD=tesseract
TESSERACT_CONFIDENCE_THRESHOLD=60
USE_PYTESSERACT_AUDIT=True

# ============================================================================
# RECAPTCHA CONFIGURATION
# ============================================================================

RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here

# ============================================================================
# CORS AND SECURITY SETTINGS
# ============================================================================

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# SOCIAL LOGIN (Google & Facebook OAuth2)
# ============================================================================

# Google OAuth2
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:8000/auth/google/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional: force redirect URI (useful behind reverse proxies)
# GOOGLE_REDIRECT_URI=https://www.yourdomain.com/auth/google/callback/

# Facebook OAuth2
# Get from: https://developers.facebook.com/ → Your App → Settings → Basic
# Valid OAuth Redirect URIs: http://localhost:8000/auth/facebook/callback/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
# Optional: force redirect URI (useful behind reverse proxies)
# FACEBOOK_REDIRECT_URI=https://www.yourdomain.com/auth/facebook/callback/

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============================================================================
# ANOMALY DETECTION THRESHOLDS
# ============================================================================

DUPLICATE_PERCENTAGE_THRESHOLD=50
DUPLICATE_AMOUNT_PERCENTAGE_THRESHOLD=10
MISSING_QUANTITY_THRESHOLD=1000000
INVOICE_AGE_DAYS_THRESHOLD=90
DUPLICATE_RISK_THRESHOLD=0.7

# ============================================================================
# REFERENCE NOTES
# ============================================================================

# 1. Copy this file: cp backend/.env.example backend/.env
# 2. Edit backend/.env with your actual credentials
# 3. Never commit backend/.env to git (it's in .gitignore)
# 4. For each environment (dev/staging/prod), use appropriate credentials
# 5. Rotate secrets regularly in production



GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://www.tadgeeg.com/auth/google/callback/
