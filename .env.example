# FinAI Production Configuration
# Copy this to .env and fill in with actual values

# ===== Core Django Configuration =====
SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ===== Database Configuration =====
USE_SQLITE=True
# For PostgreSQL (production):
# USE_SQLITE=False
# DB_NAME=finai_db
# DB_USER=postgres
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=5432

# ===== OpenAI API Configuration (REQUIRED for AI features) =====
# Get API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-actual-key-here

# Model selection
OPENAI_MODEL=gpt-4o-mini                # For text extraction, analysis, explanations
OPENAI_VISION_MODEL=gpt-4o-mini         # For document OCR and image processing
OPENAI_TIMEOUT=120                       # Seconds to wait for API response
OPENAI_MAX_TOKENS=2000                   # Maximum tokens in each response
OPENAI_TEMPERATURE=0.3                   # 0 = deterministic, 1 = creative

# ===== File Processing Configuration =====
MAX_UPLOAD_SIZE_MB=50                    # Maximum file size in MB
MAX_OCR_PAGES=20                         # Maximum PDF pages to process (use 1-20)
ALLOWED_DOCUMENT_TYPES=pdf,jpeg,png,jpg  # Comma-separated supported types

# ===== AI Rate Limiting =====
AI_RATE_LIMIT_REQUESTS=100               # Max requests per period
AI_RATE_LIMIT_PERIOD=3600                # Period in seconds (3600 = 1 hour)

# ===== CORS Configuration =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8001

# ===== Legacy Emergent Integration (Deprecated) =====
# EMERGENT_LLM_KEY=your-emergent-key  # No longer used, kept for backward compat

# ===== Optional: Celery/Redis (for async processing) =====
# Uncomment if you want to enable async PDF/heavy document processing
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ===== Optional: Tesseract OCR Fallback =====
# Path to Tesseract executable (usually auto-detected on Linux/Mac)
# TESSERACT_CMD=/usr/bin/tesseract
